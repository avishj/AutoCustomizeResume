{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI",
      "type": "debugpy",
      "request": "launch",
      "module": "autocustomizeresume",
      // Update args to match your CLI commands
      "args": ["hello", "world"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "AUTOCUSTOMIZERESUME_VERBOSE": "true"
      }
    }
  ]
}
